# Copy to .env and fill in real values. Never commit .env to version control.

# ── Server ───────────────────────────────────────────────────
SERVER_PORT=3030
METRICS_PORT=9090
LOG_LEVEL=info                        # debug | info | warn | error

# Fiber timeouts (seconds)
FIBER_READ_TIMEOUT_SECONDS=30
FIBER_WRITE_TIMEOUT_SECONDS=30
FIBER_IDLE_TIMEOUT_SECONDS=120
FIBER_CONCURRENCY=262144              # max simultaneous goroutines (256K)

# Max request body size in MB
MAX_REQUEST_SIZE_MB=10

# How long to wait for in-flight requests during graceful shutdown
GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30

# ── Auth ─────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=change-me-use-a-32-byte-random-hex-string

# ── Redis ────────────────────────────────────────────────────
# REQUIRED
REDIS_URL=redis://localhost:6379

# ── Kafka ────────────────────────────────────────────────────
# Comma-separated list of broker addresses
KAFKA_BROKERS=localhost:9092
KAFKA_RETRIES=3
KAFKA_RETRY_BACKOFF_MS=200
# TLS + SASL — both SHOULD be enabled in production
KAFKA_TLS_ENABLED=false
KAFKA_SASL_ENABLED=false
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SASL_MECHANISM=PLAIN           # PLAIN | SCRAM-SHA-256 | SCRAM-SHA-512

# ── gRPC ─────────────────────────────────────────────────────
GRPC_SERVICE_URL=localhost:50051
GRPC_MAX_RETRIES=3
GRPC_RETRY_BASE_DELAY_MS=100
# Enable TLS when the downstream gRPC service uses a CA-signed certificate.
# Set GRPC_SERVER_NAME_OVERRIDE only for self-signed staging certs.
GRPC_TLS_ENABLED=false
GRPC_SERVER_NAME_OVERRIDE=

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100              # max requests per window per IP/user
RATE_LIMIT_WINDOW_SECONDS=60
# false = fail-closed (use local fallback when Redis is down) — recommended for fintech
# true  = fail-open  (allow all requests when Redis is down)
RATE_LIMIT_FAIL_OPEN=false

# ── Cache ─────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300                # 5 minutes

# ── Circuit breaker ───────────────────────────────────────────
CB_MAX_REQUESTS=5                    # probe requests allowed in half-open state
CB_INTERVAL_SECONDS=60               # failure-count reset interval (closed state)
CB_TIMEOUT_SECONDS=30                # how long to stay open before probing
CB_FAILURE_RATIO=0.6                 # 60% error rate trips the breaker

# ── Load shedding ─────────────────────────────────────────────
LOAD_SHED_MAX_CONNECTIONS=10000      # in-flight requests before 503 is returned

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=*               # use specific origin in production

# ── Request timeout ───────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30

# ── Metrics auth ──────────────────────────────────────────────
# If set, /metrics requires: Authorization: Bearer <token>
# Recommended: set to a long random string in production
METRICS_AUTH_TOKEN=
